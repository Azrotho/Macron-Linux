#!/bin/bash
# en-marche — Le gestionnaire de paquets disruptif de la Start-up Nation 🇫🇷

set -euo pipefail

show_help() {
    echo -e "\e[1;34m=== en-marche — Gestionnaire de paquets de la Start-up Nation ===\e[0m"
    echo "Usage:"
    echo "  en-marche installer <paquet>   - Intégrer un actif technologique (pacman -S)"
    echo "  en-marche supprimer <paquet>   - Restructurer/licencier un paquet (pacman -Rns)"
    echo "  en-marche rechercher <terme>   - Sourcer des innovations sur le marché (pacman -Ss)"
    echo "  en-marche moderniser           - Lancer la grande réforme du système (pacman -Syu)"
    echo ""
    echo "Exemple : en-marche installer fastfetch"
}

if [ "$#" -eq 0 ]; then
    show_help
    exit 1
fi

run_pacman_with_keyring_fallback() {
    if ! sudo pacman "$@"; then
        echo -e "\n\e[1;31m[en-marche]\e[0m Erreur de transaction Pacman détectée (clés obsolètes ou corrompues)."
        read -p "[en-marche] Voulez-vous que la Start-up Nation modernise vos clés de confiance automatiquement ? [O/n] : " -n 1 -r REPLY
        echo
        if [[ $REPLY =~ ^[OoYy]$ ]] || [ -z "$REPLY" ]; then
            echo -e "\e[1;34m[en-marche]\e[0m Grande réforme structurelle du trousseau de clés..."
            sudo pacman -Sy --noconfirm archlinux-keyring
            sudo pacman-key --init
            sudo pacman-key --populate archlinux
            echo -e "\e[1;32m[en-marche]\e[0m Clés de confiance mises à jour. Nouvelle tentative d'installation..."
            sudo pacman "$@"
        else
            echo -e "\e[1;31m[en-marche]\e[0m Annulation de la réforme des clés."
            exit 1
        fi
    fi
}

CMD="$1"
shift

case "$CMD" in
    installer)
        if [ "$#" -eq 0 ]; then
            echo "Erreur : Spécifiez un actif technologique à installer."
            exit 1
        fi
        echo -e "\e[1;34m[en-marche]\e[0m Négociation sur le marché des paquets pour installer $*..."
        run_pacman_with_keyring_fallback -S "$@"
        ;;
    supprimer)
        if [ "$#" -eq 0 ]; then
            echo "Erreur : Spécifiez le paquet à restructurer."
            exit 1
        fi
        echo -e "\e[1;31m[en-marche]\e[0m Restructuration en cours de $* (rupture conventionnelle)..."
        sudo pacman -Rns "$@"
        ;;
    rechercher)
        if [ "$#" -eq 0 ]; then
            echo "Erreur : Spécifiez un terme à rechercher."
            exit 1
        fi
        echo -e "\e[1;34m[en-marche]\e[0m Sourcing d'actifs technologiques correspondant à '$*'..."
        pacman -Ss "$@"
        ;;
    moderniser)
        echo -e "\e[1;32m[en-marche]\e[0m Lancement de la grande réforme structurelle du système..."
        run_pacman_with_keyring_fallback -Syu
        ;;
    *)
        echo -e "Commande disruptive inconnue : $CMD"
        show_help
        exit 1
        ;;
esac
