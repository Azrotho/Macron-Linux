#!/bin/bash
# doctolib — Service de la Start-up Nation 🇫🇷

echo -e "\e[1;34m=== DOCTOLIB ===\e[0m"
echo -e "\e[3m\"Optimisez votre capital santé en trois clics.\"\e[0m"
echo ""
echo -e "Disruption de l'accès aux soins par créneaux horaires.
\"Prenez rendez-vous avec la modernité médicale. Attention, aucun remboursement garanti par ordonnance.\""
echo ""
echo -e "Lien officiel : \e[4;32mhttps://www.doctolib.fr\e[0m"
echo ""

# Si un serveur d'affichage est présent (X11 ou Wayland), on ouvre le navigateur
if [ -n "${DISPLAY:-}" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; then
    echo "Lancement du navigateur souverain..."
    xdg-open "https://www.doctolib.fr" &>/dev/null &
fi
