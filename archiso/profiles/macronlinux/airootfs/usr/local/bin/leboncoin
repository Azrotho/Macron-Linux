#!/bin/bash
# leboncoin — Service de la Start-up Nation 🇫🇷

echo -e "\e[1;34m=== LE BON COIN ===\e[0m"
echo -e "\e[3m\"Pour vendre vos actifs non stratégiques ou trouver un costard pour traverser la rue.\"\e[0m"
echo ""
echo -e "Division Économie Circulaire et Transition Solidaire de la Start-up Nation.
\"Rupture conventionnelle de vos objets encombrants.\""
echo ""
echo -e "Lien officiel : \e[4;32mhttps://www.leboncoin.fr\e[0m"
echo ""

# Si un serveur d'affichage est présent (X11 ou Wayland), on ouvre le navigateur
if [ -n "${DISPLAY:-}" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; then
    echo "Lancement du navigateur souverain..."
    xdg-open "https://www.leboncoin.fr" &>/dev/null &
fi
