#!/bin/bash
# monespacesante — Service de la Start-up Nation 🇫🇷

echo -e "\e[1;34m=== MON ESPACE SANTÉ ===\e[0m"
echo -e "\e[3m\"Votre coffre-fort médical national (consultable par les premiers de cordée).\"\e[0m"
echo ""
echo -e "La numérisation de votre capital vital.\n\"Vos données de santé sécurisées et partagées... pour un meilleur suivi de votre employabilité physique !\""
echo ""
echo -e "Lien officiel : \e[4;32mhttps://www.monespacesante.fr\e[0m"
echo ""

# Si un serveur d'affichage est présent (X11 ou Wayland), on ouvre le navigateur
if [ -n "${DISPLAY:-}" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; then
    echo "Lancement du navigateur souverain..."
    xdg-open "https://www.monespacesante.fr" &>/dev/null &
fi
