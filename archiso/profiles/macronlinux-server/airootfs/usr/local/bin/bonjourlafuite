#!/bin/bash
# bonjourlafuite — Service de la Start-up Nation 🇫🇷

echo -e "\e[1;34m=== BONJOUR LA FUITE ===\e[0m"
echo -e "\e[3m\"Le tableau de bord de la transparence des données de la Start-up Nation.\"\e[0m"
echo ""
echo -e "Division Transparence et Partage Involontaire d'Actifs Numériques.\n\"Parce que vos données personnelles méritent de voyager librement. Suivez la grande braderie de nos bases de données publiques !\""
echo ""
echo -e "Lien officiel : \e[4;32mhttps://bonjourlafuite.eu.org\e[0m"
echo ""

# Si un serveur d'affichage est présent (X11 ou Wayland), on ouvre le navigateur
if [ -n "${DISPLAY:-}" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; then
    echo "Lancement du navigateur souverain..."
    xdg-open "https://bonjourlafuite.eu.org" &>/dev/null &
fi
