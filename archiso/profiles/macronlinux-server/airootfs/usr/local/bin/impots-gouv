#!/bin/bash
# impots-gouv — Service de la Start-up Nation 🇫🇷

echo -e "\e[1;34m=== IMPÔTS GOUV ===\e[0m"
echo -e "\e[3m\"Le prélèvement à la source, l'obligation fiscale suprême pour le financement de la nation.\"\e[0m"
echo ""
echo -e "Prélèvement à la source et civisme fiscal disruptif.
\"Parce que déclarer est un devoir, prélever est notre savoir-faire. Soyez fiers de payer !\""
echo ""
echo -e "Lien officiel : \e[4;32mhttps://www.impots.gouv.fr\e[0m"
echo ""

# Si un serveur d'affichage est présent (X11 ou Wayland), on ouvre le navigateur
if [ -n "${DISPLAY:-}" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; then
    echo "Lancement du navigateur souverain..."
    xdg-open "https://www.impots.gouv.fr" &>/dev/null &
fi
