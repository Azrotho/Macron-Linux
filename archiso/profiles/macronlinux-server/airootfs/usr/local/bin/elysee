#!/bin/bash
# elysee — Service de la Start-up Nation 🇫🇷

echo -e "\e[1;34m=== ÉLYSÉE ===\e[0m"
echo -e "\e[3m\"Le cœur battant du pouvoir réformateur et disruptif.\"\e[0m"
echo ""
echo -e "Présidence de la Start-up Nation française.\n\"Rendre la France plus compétitive par ordonnances souveraines et bienveillantes. Entrez dans le bureau des réformes !\""
echo ""
echo -e "Lien officiel : \e[4;32mhttps://www.elysee.fr\e[0m"
echo ""

# Si un serveur d'affichage est présent (X11 ou Wayland), on ouvre le navigateur
if [ -n "${DISPLAY:-}" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; then
    echo "Lancement du navigateur souverain..."
    xdg-open "https://www.elysee.fr" &>/dev/null &
fi
